generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

enum StaffRole {
  CASHIER
  WAITRESS
  RUNNER
  KITCHEN
}

enum ServiceChannel {
  DELIVERY
  LOCAL
  PICKUP
}

enum OrderType {
  DELIVERY
  PICKUP
  TABLE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MERCADO_PAGO
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum TableStatus {
  FREE
  OCCUPIED
  WAITING
  FINISHED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  EXPENSE
  WITHDRAWAL
  DEPOSIT
}

enum TableCallStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}

enum DeliveryAssignmentStatus {
  ASSIGNED
  PICKED_UP
  DELIVERED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum DiscountType {
  PERCENT
  FIXED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  email                 String               @unique
  passwordHash          String
  role                  UserRole
  staffRole             StaffRole?
  phone                 String?
  pinHash               String?
  avatarUrl             String?
  active                Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  accounts              Account[]
  sessions              Session[]
  createdOrders         Order[]              @relation("OrderCreatedBy")
  tableSessions         TableSession[]       @relation("WaitressSessions")
  changedOrderStatuses  OrderStatusHistory[] @relation("OrderStatusChangedBy")
  auditLogs             AuditLog[]           @relation("AuditLogCreatedBy")
  cashSessionsOpened    CashSession[]        @relation("CashOpenedBy")
  cashSessionsClosed    CashSession[]        @relation("CashClosedBy")
  cashMovements         CashMovement[]       @relation("CashMovementBy")
  deliveryAssignments   DeliveryAssignment[] @relation("RunnerAssignments")
  tableCallsAck         TableCall[]          @relation("TableCallAckBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id         String               @id @default(cuid())
  slug       String               @unique
  name       String
  icon       String
  sortOrder  Int                  @default(0)
  active     Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  deletedAt  DateTime?
  products   Product[]
  promotions PromotionCategory[]
}

model Product {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  description     String
  basePrice       Decimal          @db.Decimal(10, 2)
  imageUrl        String
  featured        Boolean          @default(false)
  available       Boolean          @default(true)
  trackStock      Boolean          @default(false)
  stock           Int?
  lowStockThreshold Int            @default(5)
  preparationTime Int              @default(0)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  options         ProductOption[]
  images          ProductImage[]
  orderItems      OrderItem[]
  promotions      PromotionProduct[]
}

model ProductOption {
  id         String          @id @default(cuid())
  productId  String
  name       String
  required   Boolean         @default(false)
  multiple   Boolean         @default(false)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  choices    ProductChoice[]
}

model ProductChoice {
  id            String        @id @default(cuid())
  optionId      String
  name          String
  priceModifier Decimal       @db.Decimal(10, 2)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  option        ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  alt        String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Promotion {
  id          String              @id @default(cuid())
  title       String
  description String
  imageUrl    String
  discount    Decimal             @db.Decimal(5, 2)
  validFrom   DateTime
  validTo     DateTime
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  products    PromotionProduct[]
  categories  PromotionCategory[]
}

model PromotionProduct {
  promotionId String
  productId   String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
}

model PromotionCategory {
  promotionId String
  categoryId  String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([promotionId, categoryId])
}

model BusinessSettings {
  id             String   @id
  name           String
  logo           String
  isOpen         Boolean  @default(true)
  openTime       String
  closeTime      String
  timezone       String   @default("America/Argentina/Buenos_Aires")
  phone          String
  address        String
  instagram      String?
  facebook       String?
  whatsapp       String
  deliveryFee    Decimal  @db.Decimal(10, 2)
  minOrderAmount Decimal  @db.Decimal(10, 2)
  taxRate        Decimal  @db.Decimal(5, 4)
  mercadoPagoEnabled Boolean @default(true)
  updatedAt      DateTime @updatedAt
}

model ChannelSettings {
  channel ServiceChannel @id
  enabled Boolean        @default(true)
}

model ChannelSchedule {
  id         String         @id @default(cuid())
  channel    ServiceChannel
  label      String
  startTime  String
  endTime    String
  daysOfWeek Int[]
  active     Boolean        @default(true)
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model DiningTable {
  id         String         @id @default(cuid())
  number     Int            @unique
  capacity   Int
  status     TableStatus    @default(FREE)
  active     Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  orders     Order[]
  sessions   TableSession[]
  tableCalls TableCall[]
  reservations TableReservation[]
}

model TableSession {
  id               String      @id @default(cuid())
  tableId          String
  waitressId       String?
  openedAt         DateTime    @default(now())
  closedAt         DateTime?
  accumulatedTotal Decimal     @default(0) @db.Decimal(10, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  table            DiningTable @relation(fields: [tableId], references: [id])
  waitress         User?       @relation("WaitressSessions", fields: [waitressId], references: [id])
  orders           Order[]
}

model Order {
  id                     String               @id @default(cuid())
  displayCode            String               @unique
  publicTrackingCode     String               @unique
  type                   OrderType
  status                 OrderStatus          @default(PENDING)
  paymentMethod          PaymentMethod
  customerName           String
  customerPhone          String
  customerAddress        String?
  deliveryLat            Float?
  deliveryLng            Float?
  notes                  String?
  subtotal               Decimal              @db.Decimal(10, 2)
  tax                    Decimal              @db.Decimal(10, 2)
  deliveryFee            Decimal              @default(0) @db.Decimal(10, 2)
  tip                    Decimal              @default(0) @db.Decimal(10, 2)
  discountCode           String?
  discountAmount         Decimal              @default(0) @db.Decimal(10, 2)
  deliveryZoneId         String?
  customerId             String?
  total                  Decimal              @db.Decimal(10, 2)
  kitchenAckAt           DateTime?
  whatsappMessage        String?
  whatsappSentAt         DateTime?
  diningTableId          String?
  tableSessionId         String?
  createdByUserId        String?
  deletedFromOperationsAt DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  diningTable            DiningTable?         @relation(fields: [diningTableId], references: [id])
  tableSession           TableSession?        @relation(fields: [tableSessionId], references: [id])
  createdByUser          User?                @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])
  deliveryZone           DeliveryZone?        @relation(fields: [deliveryZoneId], references: [id])
  customer               Customer?            @relation(fields: [customerId], references: [id])
  items                  OrderItem[]
  payment                Payment?
  statusHistory          OrderStatusHistory[]
  auditLogs              AuditLog[]
  deliveryAssignment     DeliveryAssignment?
  invoice                Invoice?
}

model OrderItem {
  id                 String               @id @default(cuid())
  orderId            String
  productId          String?
  productName        String
  productDescription String?
  basePrice          Decimal              @db.Decimal(10, 2)
  unitPrice          Decimal              @db.Decimal(10, 2)
  imageUrl           String?
  quantity           Int
  notes              String?
  createdAt          DateTime             @default(now())
  order              Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product?             @relation(fields: [productId], references: [id])
  selections         OrderItemSelection[]
}

model OrderItemSelection {
  id            String   @id @default(cuid())
  orderItemId   String
  optionName    String
  choiceName    String
  priceModifier Decimal  @db.Decimal(10, 2)
  orderItem     OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model Payment {
  id                  String        @id @default(cuid())
  orderId             String        @unique
  provider            String
  providerPaymentId   String?
  providerPreferenceId String?
  externalReference   String?
  initPoint           String?
  sandboxInitPoint    String?
  method              PaymentMethod
  status              PaymentStatus @default(PENDING)
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("ARS")
  rawPayload          Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId         String
  status          OrderStatus
  note            String?
  changedByUserId String?
  createdAt       DateTime    @default(now())
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser   User?       @relation("OrderStatusChangedBy", fields: [changedByUserId], references: [id])
}

model AuditLog {
  id              String   @id @default(cuid())
  action          String
  entityType      String
  entityId        String
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime @default(now())
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id])
  createdByUser   User?    @relation("AuditLogCreatedBy", fields: [createdByUserId], references: [id])
}

model CashSession {
  id              String            @id @default(cuid())
  status          CashSessionStatus @default(OPEN)
  openingAmount   Decimal           @db.Decimal(10, 2)
  closingAmount   Decimal?          @db.Decimal(10, 2)
  expectedAmount  Decimal?          @db.Decimal(10, 2)
  difference      Decimal?          @db.Decimal(10, 2)
  notes           String?
  openedByUserId  String
  closedByUserId  String?
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  openedByUser    User              @relation("CashOpenedBy", fields: [openedByUserId], references: [id])
  closedByUser    User?             @relation("CashClosedBy", fields: [closedByUserId], references: [id])
  movements       CashMovement[]
}

model CashMovement {
  id              String           @id @default(cuid())
  sessionId       String
  type            CashMovementType
  amount          Decimal          @db.Decimal(10, 2)
  description     String
  createdByUserId String
  createdAt       DateTime         @default(now())
  session         CashSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdByUser   User             @relation("CashMovementBy", fields: [createdByUserId], references: [id])
}

enum DeliveryZoneGeoType {
  RADIUS
  POLYGON
}

model DeliveryZone {
  id             String              @id @default(cuid())
  name           String
  deliveryFee    Decimal             @db.Decimal(10, 2)
  minOrderAmount Decimal             @default(0) @db.Decimal(10, 2)
  active         Boolean             @default(true)
  sortOrder      Int                 @default(0)
  geoType        DeliveryZoneGeoType @default(RADIUS)
  centerLat      Float?
  centerLng      Float?
  radiusKm       Float?
  polygon        Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  orders         Order[]
}

model DiscountCode {
  id              String       @id @default(cuid())
  code            String       @unique
  type            DiscountType
  value           Decimal      @db.Decimal(10, 2)
  minOrderAmount  Decimal      @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  maxUses         Int?
  usedCount       Int          @default(0)
  validFrom       DateTime
  validTo         DateTime
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  phone       String   @unique
  name        String
  addresses   Json     @default("[]")
  orderCount  Int      @default(0)
  totalSpent  Decimal  @default(0) @db.Decimal(10, 2)
  lastOrderAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model TableCall {
  id                   String          @id @default(cuid())
  tableId              String
  status               TableCallStatus @default(PENDING)
  createdAt            DateTime        @default(now())
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?
  table                DiningTable     @relation(fields: [tableId], references: [id])
  acknowledgedByUser   User?         @relation("TableCallAckBy", fields: [acknowledgedByUserId], references: [id])
}

model TableReservation {
  id            String            @id @default(cuid())
  customerName  String
  customerPhone String
  partySize     Int
  reservedAt    DateTime
  durationMinutes Int             @default(90)
  status        ReservationStatus @default(PENDING)
  notes         String?
  tableId       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  table         DiningTable?      @relation(fields: [tableId], references: [id])
}

model DeliveryAssignment {
  id          String                   @id @default(cuid())
  orderId     String                   @unique
  runnerId    String
  status      DeliveryAssignmentStatus @default(ASSIGNED)
  deliveryFee Decimal                  @default(0) @db.Decimal(10, 2)
  assignedAt  DateTime                 @default(now())
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  order       Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  runner      User                     @relation("RunnerAssignments", fields: [runnerId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  orderId       String        @unique
  number        String        @unique
  customerName  String
  customerTaxId String?
  subtotal      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
